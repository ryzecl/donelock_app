# https://github.com/flutter/flutter/blob/main/packages/flutter_tools/templates/app/gitignore.tmpl

# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Web related
.web-clipper/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android local properties and signing keys
android/local.properties
android/key.properties
android/app/local.properties
android/app/key.properties
*.keystore
*.jks

# iOS/macOS files
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/macos/Flutter/Generated.xcconfig
**/macos/Flutter/flutter_export_environment.sh
**/ios/Flutter/ephemeral/
**/macos/Flutter/ephemeral/
**/ios/Pods/
**/ios/.symlinks/
**/macos/Pods/
**/macos/.symlinks/
*.xcworkspace
!**/ios/*.xcworkspace
!**/macos/*.xcworkspace

# Coverage
/coverage/

# Windows related
/windows/flutter/ephemeral/

# Linux related
/linux/flutter/ephemeral/

# Environment files / API keys
.env
.env*
*.env

# Build outputs
*.apk
*.aab

# Memory dumps
*.hprof
